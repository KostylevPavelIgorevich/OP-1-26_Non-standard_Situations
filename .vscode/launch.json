{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node-terminal",
            "name": "Run Script: tauri",
            "request": "launch",
            "command": "npm run tauri dev",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "publish local backend",
            "linux": {
                "env": {
                    "BACKEND_EXECUTABLE": "${workspaceFolder}/bin/local-backend/Backend"
                }
            },
            "osx": {
                "env": {
                    "BACKEND_EXECUTABLE": "${workspaceFolder}/bin/local-backend/Backend"
                }
            },
            "windows": {
                "env": {
                    "BACKEND_EXECUTABLE": "${workspaceFolder}\\bin\\local-backend\\Backend.exe"
                }
            }
        }
    ]
}